server {
    listen 80;
    server_name hiwebsun.top www.hiwebsun.top;

    # 续期时 HTTP-01 验证放行
    location ^~ /.well-known/acme-challenge/ {
        root /var/www/letsencrypt;
    }

    # 其余全部跳到 HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name hiwebsun.top www.hiwebsun.top;

    ssl_certificate     /etc/letsencrypt/live/hiwebsun.top/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hiwebsun.top/privkey.pem;

    # 统一 301 到 a1.ccyyff.cn，带上原路径和查询
    return 301 https://a1.ccyyff.cn$request_uri;
}