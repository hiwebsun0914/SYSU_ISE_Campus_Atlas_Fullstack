# Node service
PORT=3000
JWT_SECRET=replace-with-a-long-random-string
JWT_CLOCK_SKEW=5
VERIFY_LAST_TOKEN=false

# Optional: use a custom location for users.json
# USERS_FILE=/absolute/path/to/users.json

# Tencent Cloud Object Storage (needed for avatar/check-in uploads)
COS_BUCKET=your-bucket-name
COS_REGION=ap-guangzhou
PUBLIC_ASSET_DOMAIN=https://your-public-asset-domain.example.com

# Some routes use COS_* names; others use TENCENT_* names.
# Until the server code is unified, set both pairs to the same credentials.
COS_SECRET_ID=replace-me
COS_SECRET_KEY=replace-me
TENCENT_SECRET_ID=replace-me
TENCENT_SECRET_KEY=replace-me
STS_DURATION=300

