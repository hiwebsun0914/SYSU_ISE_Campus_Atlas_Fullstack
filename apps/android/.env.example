# Browser development can use a local backend.
VITE_API_BASE=http://localhost:3000

# The installed Android app cannot use the Vite development proxy.
VITE_NATIVE_API_BASE=https://your-domain.example.com/api
VITE_NATIVE_API_CREDENTIALS=omit
VITE_API_FORCE_X_REQUESTED_WITH=0
VITE_API_DEBUG=0
VITE_API_TIMEOUT=10000
VITE_API_RETRY=0

